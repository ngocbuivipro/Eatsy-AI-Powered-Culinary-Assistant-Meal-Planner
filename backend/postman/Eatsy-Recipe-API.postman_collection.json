{
  "info": {
    "_postman_id": "f0d7a271-2e56-4e3a-a5f4-8f2db30217b6",
    "name": "Eatsy Recipe API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "name",
      "value": "Thanh Mai"
    },
    {
      "key": "email",
      "value": "thanhmai.recipe@example.com"
    },
    {
      "key": "password",
      "value": "123456"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "recipeId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Register User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) {",
              "  const json = pm.response.json();",
              "  pm.collectionVariables.set('token', json.data.token);",
              "  pm.collectionVariables.set('userId', json.data.user._id);",
              "}",
              "pm.test('Register returns 201 or duplicate-safe 400', function () {",
              "  pm.expect([201, 400]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{name}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "register"
          ]
        }
      }
    },
    {
      "name": "2. Login User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('token', json.data.token);",
              "pm.collectionVariables.set('userId', json.data.user._id);",
              "pm.test('Login returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Token is returned', function () {",
              "  pm.expect(json.data.token).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "login"
          ]
        }
      }
    },
    {
      "name": "3. Create Recipe - Success",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('recipeId', json.data.recipe._id);",
              "pm.test('Create recipe returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "pm.test('Recipe author matches logged-in user', function () {",
              "  pm.expect(json.data.recipe.author).to.eql(pm.collectionVariables.get('userId'));",
              "});",
              "pm.test('Recipe source is user', function () {",
              "  pm.expect(json.data.recipe.source).to.eql('user');",
              "});",
              "pm.test('Client author is ignored', function () {",
              "  pm.expect(json.data.recipe.author).to.not.eql('000000000000000000000000');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Com chien trung\",\n  \"description\": \"Mon com chien don gian cho bua trua\",\n  \"ingredients\": [\n    {\n      \"name\": \"Com nguoi\",\n      \"quantity\": 1,\n      \"unit\": \"bat\"\n    },\n    {\n      \"name\": \"Trung ga\",\n      \"quantity\": 2,\n      \"unit\": \"qua\"\n    }\n  ],\n  \"steps\": [\n    {\n      \"order\": 1,\n      \"instruction\": \"Danh tan trung\"\n    },\n    {\n      \"order\": 2,\n      \"instruction\": \"Xao com voi trung den khi chin deu\"\n    }\n  ],\n  \"difficulty\": \"easy\",\n  \"mealType\": [\"lunch\"],\n  \"prepTime\": 10,\n  \"cookTime\": 15,\n  \"servings\": 2,\n  \"nutrition\": {\n    \"calories\": 420,\n    \"protein\": 18,\n    \"carbohydrates\": 45,\n    \"fat\": 16,\n    \"fiber\": 2\n  },\n  \"imageUrl\": \"https://example.com/com-chien-trung.jpg\",\n  \"tags\": [\"com chien\", \"trung\"],\n  \"author\": \"000000000000000000000000\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/recipes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "recipes"
          ]
        }
      }
    },
    {
      "name": "4. Create Recipe - Missing Ingredients",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Validation returns 400', function () {",
              "  pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Mon loi\",\n  \"description\": \"Khong co ingredient hop le\",\n  \"ingredients\": [],\n  \"steps\": [\n    {\n      \"order\": 1,\n      \"instruction\": \"Thu tao mon\"\n    }\n  ],\n  \"prepTime\": 5,\n  \"cookTime\": 5,\n  \"servings\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/recipes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "recipes"
          ]
        }
      }
    },
    {
      "name": "5. Create Recipe - Unauthorized",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Unauthorized returns 401', function () {",
              "  pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Mon khong token\",\n  \"description\": \"Request nay phai bi chan\",\n  \"ingredients\": [\n    {\n      \"name\": \"Trung ga\",\n      \"quantity\": 1,\n      \"unit\": \"qua\"\n    }\n  ],\n  \"steps\": [\n    {\n      \"order\": 1,\n      \"instruction\": \"Nau thu\"\n    }\n  ],\n  \"prepTime\": 5,\n  \"cookTime\": 5,\n  \"servings\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/recipes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "recipes"
          ]
        }
      }
    }
  ]
}
